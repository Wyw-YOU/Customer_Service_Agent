# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/mall_agent
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/mall_agent

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333

# LLM API (DeepSeek / Qwen / OpenAI Compatible)
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# Embedding
EMBEDDING_MODEL=text-embedding-3-small

# JWT
JWT_SECRET=change-me-to-a-random-secret-key
JWT_EXPIRE_MINUTES=1440

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
